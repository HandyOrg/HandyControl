                         StartPoint="0%,0%">
        <GradientStop Color="{StaticResource DarkWarningColor}"
                      Offset="0" />
        <GradientStop Color="{StaticResource DarkWarningColor}"
                      Offset="0.5" />
        <GradientStop Color="{StaticResource BackgroundColor}"
                      Offset="0.5" />
        <GradientStop Color="{StaticResource BackgroundColor}"
                      Offset="1" />
