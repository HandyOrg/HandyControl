<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:vm="clr-namespace:HandyControlDemo.ViewModel"
             xmlns:data="clr-namespace:HandyControlDemo.Data"
             xmlns:cv="clr-namespace:HandyControlDemo.Tools.Converter"
             x:Class="HandyControlDemo.UserControl.HoneycombPanelDemo"
             x:DataType="vm:CardDemoViewModel"
             DataContext="{Binding CardDemo, Source={x:Static vm:ViewModelLocator.Instance}}">
    <UserControl.Resources>
        <cv:StringToBitmapConverter x:Key="StringToBitmap" />
    </UserControl.Resources>
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal"
                    Spacing="8"
                    Margin="0,0,0,16">
            <Button Command="{Binding AddItemCommand}" Content="Add" />
            <Button Command="{Binding RemoveItemCommand}" Content="Remove" />
        </StackPanel>
        <ItemsControl Grid.Row="1"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      ItemsSource="{Binding DataList}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <hc:HoneycombPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="data:CardModel">
                    <Border Width="60"
                            Height="60"
                            Margin="6"
                            CornerRadius="30"
                            ClipToBounds="True">
                        <Image Source="{Binding Content, Converter={StaticResource StringToBitmap}}"
                               Stretch="UniformToFill" />
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
